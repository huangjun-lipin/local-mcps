    "dev": "vite build --watch",
    "build": "vite build",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "@crxjs/vite-plugin": "^2.0.0-beta.28"
  }
}
