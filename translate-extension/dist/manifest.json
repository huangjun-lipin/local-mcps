{
  "manifest_version": 3,
  "name": "智能翻译助手",
  "version": "1.0.0",
  "description": "选中网页/PDF/视频中的文字即可翻译，支持多语言切换",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "翻译当前选中文字"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "智能翻译助手"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/webpage.ts-loader-Cyw_zJFe.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "js": [
        "assets/subtitle.ts-loader-ByoKsK1b.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "js": [
        "assets/pdf.ts-loader-D1r7kFMZ.js"
      ],
      "matches": [
        "*://*/*.pdf",
        "file://*/*.pdf",
        "*://*/*.PDF"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/ui-DGX6BH7_.js",
        "assets/translator-Bpc-3k6W.js",
        "assets/languages-CXtdqP6-.js",
        "assets/webpage.ts-CAdu5Zj7.js",
        "assets/subtitle.ts-Cv5-z5YR.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://*/*",
        "*://*/*",
        "file://*/*"
      ],
      "resources": [
        "assets/ui-DGX6BH7_.js",
        "assets/translator-Bpc-3k6W.js",
        "assets/languages-CXtdqP6-.js",
        "assets/pdf.ts-DgMsdm8a.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
